{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qubership.org/otel-tracing-python/L1-discovery-result.schema.json",
  "title": "DiscoveryResult",
  "description": "Layer 1 output for Python tracing discovery.",
  "type": "object",
  "additionalProperties": false,
  "required": ["service", "dependencyProfile", "configuration", "instrumentation", "platformContract"],
  "properties": {
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework"],
      "properties": {
        "name": { "type": "string" },
        "framework": { "enum": ["fastapi", "django", "flask", "pure-python", "unknown"] }
      }
    },
    "dependencyProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hasOtelApi", "hasOtelSdk", "hasExporter", "hasLegacy", "artifacts"],
      "properties": {
        "hasOtelApi": { "type": "boolean" },
        "hasOtelSdk": { "type": "boolean" },
        "hasExporter": { "type": "boolean" },
        "hasLegacy": { "type": "boolean" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["coordinates", "bucket"],
            "properties": {
              "coordinates": { "type": "string", "description": "distribution name as it appears in the manifest" },
              "version": { "type": "string" },
              "scope": { "enum": ["direct", "indirect", "extra", "unknown"] },
              "bucket": { "enum": ["legacy", "modern"] },
              "technology": {
                "enum": [
                  "opentracing",
                  "jaeger-client",
                  "zipkin",
                  "otel-api",
                  "otel-sdk",
                  "otel-exporter",
                  "otel-propagator",
                  "otel-instrumentation",
                  "otel-distro",
                  "other"
                ]
              }
            }
          }
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "export": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exporter": { "enum": ["otlp", "zipkin", "jaeger", "none", "unknown"] },
            "endpoint": { "type": ["string", "null"] },
            "protocol": { "enum": ["grpc", "http-protobuf", "http-thrift", "udp", "unknown"] },
            "targetGuess": { "enum": ["otec", "jaeger-collector", "legacy-zipkin", "unknown"] }
          }
        },
        "propagation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Inject and extract are separate sets. Extract is a race (several formats tried, order decides the winner - last wins in Python, the composite chains the context through every propagator); inject is a fan-out (a composite writes EVERY configured format, a later member overrides the same carrier key). Record the effective values, resolved from the actual propagator class/env value (B3SingleFormat and env b3 inject single b3; B3MultiFormat and env b3multi inject X-B3-*; the legacy B3Format is a deprecated alias of B3MultiFormat).",
          "properties": {
            "inject": { "type": "array", "items": { "enum": ["w3c", "b3", "b3multi", "jaeger", "none", "unknown"] }, "description": "Formats written on outgoing calls, in composite order (last overrides same carrier key)." },
            "extract": { "type": "array", "items": { "enum": ["w3c", "b3", "b3multi", "jaeger", "none", "unknown"] }, "description": "Formats accepted on incoming calls, in composite order (last wins in Python)." },
            "configScope": { "enum": ["runtime", "unknown"], "description": "Runtime for Python — OTEL_PROPAGATORS or programmatic set_global_textmap; Python is interpreted, there is no build-time propagation surface." },
            "fromFrameworkDefault": { "type": "boolean", "description": "True when inject/extract come from an SDK or instrumentation default rather than explicit configuration." },
            "components": {
              "type": "object",
              "additionalProperties": { "enum": ["OK", "FAILED", "unknown"] }
            }
          }
        },
        "sampling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configured": { "type": "boolean" },
            "type": { "enum": ["always_on", "always_off", "probabilistic", "parentbased", "ratelimiting", "const", "unknown"] },
            "ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "consistentAcrossServices": { "enum": ["yes", "no", "unknown"] }
          }
        }
      }
    },
    "apiUsage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "symbol"],
        "properties": {
          "family": { "enum": ["otel", "opentracing", "zipkin", "jaeger-client", "unknown"] },
          "symbol": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "apiFamilies": {
      "type": "array",
      "items": { "enum": ["otel", "opentracing", "zipkin", "jaeger-client"] }
    },
    "instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["auto", "manual", "mixed", "none"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "asyncBoundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "enum": ["kafka-producer", "kafka-consumer", "celery-task", "thread-pool", "asyncio-executor", "subprocess", "http-client", "other"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "contextWrapper": { "type": "boolean" }
        }
      }
    },
    "platformContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceName": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": ["string", "null"] },
            "includesNamespace": { "type": "boolean" },
            "namespaceSource": { "enum": ["downward-api", "helm", "appdeployer", "sa-file", "none", "unknown"] }
          }
        },
        "samplerTier": { "enum": ["ratelimiting", "probabilistic", "const", "none", "unknown"] },
        "samplerType": { "enum": ["parentbased_traceidratio", "traceidratio", "always_on", "always_off", "ratelimiting", "const", "unknown"] },
        "propagationStandard": { "enum": ["b3multi", "b3", "w3c", "jaeger", "none", "unknown"] },
        "hasB3PropagatorExtension": { "type": "boolean" },
        "endpointFilter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configured": { "type": "boolean" },
            "excluded": { "type": "array", "items": { "type": "string" } }
          }
        },
        "logging": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "traceFieldsInPattern": { "type": "boolean" },
            "correlationDep": { "enum": ["otel-logging-instrumentation", "structlog", "python-json-logger", "custom", "none", "unknown"] }
          }
        },
        "export": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "protocol": { "enum": ["http/protobuf", "grpc", "http", "unknown"] },
            "endpointPath": { "type": ["string", "null"] },
            "tracingHost": { "type": ["string", "null"] }
          }
        }
      }
    },
    "gaps": { "type": "array", "items": { "type": "string" } }
  }
}
