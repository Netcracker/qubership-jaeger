{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qubership.org/otel-tracing-java/L1-discovery-result.schema.json",
  "title": "DiscoveryResult",
  "description": "Layer 1 output: every existing element of the tracing implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["service", "dependencyProfile", "configuration", "instrumentation", "platformContract"],
  "properties": {
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework"],
      "properties": {
        "name": { "type": "string" },
        "framework": { "enum": ["spring-boot", "quarkus", "pure-java", "unknown"] }
      }
    },
    "dependencyProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hasOtelApi", "hasOtelSdk", "hasExporter", "hasLegacy", "artifacts"],
      "properties": {
        "hasOtelApi": { "type": "boolean" },
        "hasOtelSdk": { "type": "boolean" },
        "hasExporter": { "type": "boolean" },
        "hasLegacy": { "type": "boolean" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["coordinates", "bucket"],
            "properties": {
              "coordinates": { "type": "string", "description": "groupId:artifactId" },
              "version": { "type": "string" },
              "scope": { "enum": ["compile", "runtime", "provided", "test", "managed", "unknown"] },
              "bucket": { "enum": ["legacy", "modern"] },
              "technology": { "enum": ["brave", "zipkin", "jaeger-client", "opentracing", "sleuth", "otel-api", "otel-sdk", "otel-exporter", "micrometer-bridge", "boot4-otel-starter", "quarkus-otel", "other"] }
            }
          }
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "export": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exporter": { "enum": ["otlp", "zipkin", "jaeger", "none", "unknown"] },
            "endpoint": { "type": ["string", "null"] },
            "protocol": { "enum": ["grpc", "http-protobuf", "http-thrift", "udp", "unknown"] },
            "targetGuess": { "enum": ["otec", "jaeger-collector", "legacy-zipkin", "unknown"] }
          }
        },
        "propagation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Inject and extract are separate sets. Extract is a race (several formats tried, order decides the winner); inject is a fan-out (a composite writes EVERY configured format, so OTEL_PROPAGATORS/quarkus.otel.propagators emit all listed formats). Record the effective values including framework defaults.",
          "properties": {
            "inject": { "type": "array", "items": { "enum": ["w3c", "b3", "b3multi", "jaeger", "none", "unknown"] }, "description": "Formats written on outgoing calls, in configured order." },
            "extract": { "type": "array", "items": { "enum": ["w3c", "b3", "b3multi", "jaeger", "none", "unknown"] }, "description": "Formats accepted on incoming calls, in configured order." },
            "configScope": { "enum": ["runtime", "build-time", "unknown"], "description": "build-time for quarkus.otel.propagators (rebuild required); runtime for OTEL_PROPAGATORS and Spring Boot produce/consume." },
            "fromFrameworkDefault": { "type": "boolean", "description": "True when inject/extract come from the framework default rather than an explicit key (e.g. Spring Boot consume [W3C, B3, B3_MULTI] / produce [W3C])." },
            "components": {
              "type": "object",
              "additionalProperties": { "enum": ["OK", "FAILED", "unknown"] }
            }
          }
        },
        "sampling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configured": { "type": "boolean" },
            "type": { "enum": ["always_on", "always_off", "probabilistic", "parentbased", "unknown"] },
            "ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "consistentAcrossServices": { "enum": ["yes", "no", "unknown"] }
          }
        }
      }
    },
    "apiUsage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "symbol"],
        "properties": {
          "family": { "enum": ["otel", "opentracing", "brave", "jaeger-client", "unknown"] },
          "symbol": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "apiFamilies": {
      "type": "array",
      "items": { "enum": ["otel", "opentracing", "brave", "jaeger-client"] }
    },
    "instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["auto", "manual", "mixed", "none"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "asyncBoundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "enum": ["kafka-producer", "kafka-consumer", "executor", "completable-future", "reactor", "quarkus-reactive-messaging", "other"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "contextWrapper": { "type": "boolean" }
        }
      }
    },
    "platformContract": {
      "type": "object",
      "additionalProperties": false,
      "description": "Evidence for the shared platform tracing contract (common reference/platform-tracing-guide.md).",
      "properties": {
        "serviceName": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": ["string", "null"] },
            "includesNamespace": { "type": "boolean" },
            "namespaceSource": { "enum": ["downward-api", "helm", "appdeployer", "sa-file", "none", "unknown"] }
          }
        },
        "samplerTier": { "enum": ["ratelimiting", "probabilistic", "const", "none", "unknown"] },
        "samplerType": { "enum": ["parentbased_traceidratio", "traceidratio", "always_on", "always_off", "unknown"] },
        "propagationStandard": { "enum": ["b3multi", "b3", "w3c", "jaeger", "none", "unknown"] },
        "hasB3PropagatorExtension": { "type": "boolean" },
        "endpointFilter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configured": { "type": "boolean" },
            "excluded": { "type": "array", "items": { "type": "string" } }
          }
        },
        "logging": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "traceFieldsInPattern": { "type": "boolean" },
            "correlationDep": { "enum": ["log4j", "logback", "cloudcore", "none", "unknown"] }
          }
        },
        "export": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "protocol": { "enum": ["http/protobuf", "grpc", "http", "unknown"] },
            "endpointPath": { "type": ["string", "null"] },
            "tracingHost": { "type": ["string", "null"] }
          }
        }
      }
    },
    "gaps": { "type": "array", "items": { "type": "string" } }
  }
}
